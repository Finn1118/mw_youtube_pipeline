# Copy to ".env" and set values locally. Do not commit ".env".

# Required: Deepgram (transcription + diarization)
DEEPGRAM_API_KEY=

# Required: OpenAI (speaker name mapping from transcript brief)
OPENAI_API_KEY=

# Optional: SQLite cache file path (default: ./.speaker_cache.sqlite)
SPEAKER_CACHE_PATH=./.speaker_cache.sqlite
