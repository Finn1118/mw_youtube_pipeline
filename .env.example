# Copy to ".env" and set values locally. Do not commit ".env".

# Required: Deepgram (transcription + diarization)
DEEPGRAM_API_KEY=

# Required: OpenAI (speaker name mapping from transcript brief)
OPENAI_API_KEY=

# Optional: SQLite cache file path (default: ./.speaker_cache.sqlite)
SPEAKER_CACHE_PATH=./.speaker_cache.sqlite

# Optional: YouTube cookies in base64 (bypasses IP blocks on cloud deployments).
# Export cookies.txt from your browser (Netscape format), then run:
#   base64 -w 0 cookies.txt   (Linux/Mac)
#   [Convert]::ToBase64String([IO.File]::ReadAllBytes("cookies.txt"))   (PowerShell)
# Paste the output as the value below.
YOUTUBE_COOKIES_B64=
